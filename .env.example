# DevTask Environment Variables
# Copy this file to .env and update values for production.
# Docker Compose uses these automatically.

# MySQL
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=devtask_db
MYSQL_USER=devtask
MYSQL_PASSWORD=devtask_password

# JWT – CHANGE THIS in production
JWT_SECRET=supersecret_change_in_production
JWT_EXPIRES_IN=24h

# Frontend API URL (used during Vite build)
VITE_API_URL=http://localhost:3000

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info
